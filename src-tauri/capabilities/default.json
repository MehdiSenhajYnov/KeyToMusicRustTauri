{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:webview:default",
    "core:window:default",
    "core:window:allow-destroy",
    "core:window:allow-close",
    "shell:allow-open"
  ]
}
